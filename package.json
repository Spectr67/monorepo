{
  "name": "monorepo",
  "version": "0.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build:fe": "npm run build --workspace=@monorepo/frontend",
    "build:be": "npm run build --workspace=@monorepo/backend",
    "dev:fe": "npm run dev --workspace=@monorepo/frontend",
    "dev:be": "npm run dev --workspace=@monorepo/backend",
    "build": "run-s build:fe build:be",
    "dev": "run-p dev:be dev:fe",
    "start": "node ./build/server/main.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "workspaces": [
    "backend/",
    "frontend/"
  ],
  "dependencies": {
    "@monorepo/backend": "^0.0.0",
    "@monorepo/frontend": "^0.0.0"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
